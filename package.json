{
  "name": "wcontour-js",
  "version": "0.2.1",
  "description": "A JavaScript Library of wContour.",
  "files": [
    "dist",
    "types"
  ],
  "types": "./types/index.d.ts",
  "main": "./dist/wcontour-js.umd.js",
  "module": "./dist/wcontour-js.es.js",
  "exports": {
    ".": {
      "import": "./dist/wcontour-js.es.js",
      "require": "./dist/wcontour-js.umd.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huanglii/wcontour-js.git"
  },
  "keywords": [
    "wcontour",
    "interpolate"
  ],
  "author": "huanglii",
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/huanglii/wcontour-js/issues"
  },
  "homepage": "https://github.com/huanglii/wcontour-js#readme",
  "devDependencies": {
    "@types/geojson": "^7946.0.8",
    "conventional-changelog": "^3.1.25",
    "conventional-changelog-cli": "^2.2.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
